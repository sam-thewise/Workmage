# Workmage - Environment variables
# Copy to .env and edit as needed

# Auth
SECRET_KEY=change-me-use-openssl-rand-hex-32

# OAuth (optional - configure to enable Google/Facebook/X login)
# Get credentials from: Google Cloud Console, Meta Developer, X Developer Portal
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# Database (default for Docker Compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/agentfoundry
DATABASE_SYNC_URL=postgresql://postgres:postgres@postgres:5432/agentfoundry

# Redis
REDIS_URL=redis://redis:6379/0

# Platform LLM keys (used when buyer does not use BYOK - "Use my API key")
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...  # from `stripe listen` when testing locally
# FRONTEND_URL=http://localhost:5173
# API_PUBLIC_URL=http://localhost:8000  # For OAuth callbacks; must be reachable from browser
# ENVIRONMENT=development  # set to "production" to hide internal error details

# Admin: comma-separated emails promoted to admin role on startup
# ADMIN_EMAILS=admin@example.com,superuser@example.com

# Optional: For local dev without Docker, use localhost
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentfoundry
# DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/agentfoundry
# REDIS_URL=redis://localhost:6379/0
