# Workmage - Environment variables
# Copy to .env and edit as needed

# Auth
SECRET_KEY=change-me-use-openssl-rand-hex-32

# OAuth (optional - configure to enable Google/Facebook/X login)
# Get credentials from: Google Cloud Console, Meta Developer, X Developer Portal
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# Database (default for Docker Compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/agentfoundry
DATABASE_SYNC_URL=postgresql://postgres:postgres@postgres:5432/agentfoundry

# Redis
REDIS_URL=redis://redis:6379/0

# Platform LLM keys (used when buyer does not use BYOK - "Use my API key")
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...  # from `stripe listen` when testing locally
# FRONTEND_URL=http://localhost:5173
# API_PUBLIC_URL=http://localhost:8000  # For OAuth callbacks; must be reachable from browser
# MCP_PUBLIC_URL=  # Optional: MCP endpoint URL for agent manifests (default: API_PUBLIC_URL + /api/v1/mcp)
# ENVIRONMENT=development  # set to "production" to hide internal error details

# Admin: comma-separated emails promoted to admin role on startup (restart API after change)
# ADMIN_EMAILS=admin@example.com

# ---------------------------------------------------------------------------
# Action infrastructure & MCP (Avalanche / agent wallets / live tx)
# ---------------------------------------------------------------------------
# ACTIONS_ENABLE_LIVE_TX=false
# ACTIONS_REQUIRE_APPROVAL_FOR_LIVE=true
# ACTIONS_ENABLE_REFERENCE_CAPABILITIES=true
# ACTIONS_HTTP_TIMEOUT_SEC=15
# ACTIONS_DEFAULT_MAX_SPEND_WEI=100000000000000000
# ACTIONS_DEFAULT_MAX_GAS_WEI=3000000000000000
# ACTIONS_MIN_TRUST_SCORE=20
# ACTIONS_FACTORY_ADDRESSES=   # comma-separated DEX factory addresses

# Avalanche RPC (required for simulation/broadcast and reference liquidity scan)
# AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
# AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Snowtrace / contract source and verification (Etherscan-compatible API)
# SNOWTRACE_API_URL=https://api.routescan.io/v2/network/mainnet/evm/etherscan/api
# SNOWTRACE_FUJI_API_URL=https://api.routescan.io/v2/network/testnet/evm/43113/etherscan/api
# SNOWTRACE_API_KEY=

# Signer: never commit real keys. Single key (testing) or JSON map wallet -> key
# AGENT_SIGNER_PRIVATE_KEY=0x...
# AGENT_SIGNER_KEYS={"0xYourWalletAddress":"0xYourHexPrivateKey"}

# Optional: base64 Fernet key for encrypting platform-managed signer keys (when using managed wallets).
# If unset, signer key encryption is derived from SECRET_KEY + salt. Set to rotate without changing SECRET_KEY.
# SIGNER_ENCRYPTION_KEY=

# Mint payment: user-paid Workmage Agent NFT mints
# MINT_PAYMENT_CONTRACT_AVALANCHE=0x...
# MINT_PAYMENT_CONTRACT_FUJI=0x...
# AGENT_NFT_MINTER_PRIVATE_KEY=0x...  # Holds MINTER_ROLE on WorkmageAgentNFT
# MINT_FEE_MARGIN_FACTOR=1.2
# MINT_ESTIMATED_GAS=150000
# MINT_INTENT_EXPIRY_HOURS=24

# X Authority workflow: scheduled chain run + draft creation (Celery Beat, daily)
# Set X_AUTHORITY_CHAIN_ID and X_AUTHORITY_USER_ID to enable. Chain output is parsed into ContentDraft rows.
# X_AUTHORITY_CHAIN_ID=0        # Chain ID (Trend Scout → Content Writer). 0 = disabled
# X_AUTHORITY_USER_ID=0         # User ID to attribute drafts to
# X_AUTHORITY_INPUT=            # Default input (e.g. expert handles). Empty = use default prompt
# X_AUTHORITY_MODEL=openai/gpt-5.2

# Twitter MCP proxy (twitter-automation service)
# TWITTER_MCP_URL=http://twitter-automation:8010/mcp/twitter
# TWITTER_MCP_TIMEOUT_SEC=60
# TWITTER_MCP_RETRIES=2
# TWITTER_MCP_HEALTH_PATH=/health
#
# Twitter API v2 (twitter-automation service). Get Bearer Token from X Developer Portal.
# TWITTER_BEARER_TOKEN=   # or TWITTER_AUTOMATION_BEARER_TOKEN
# TWITTER_AUTOMATION_OPERATION_TIMEOUT_SEC=45
# TWITTER_AUTOMATION_LOG_LEVEL=INFO

# Optional: For local dev without Docker, use localhost
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentfoundry
# DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/agentfoundry
# REDIS_URL=redis://localhost:6379/0
