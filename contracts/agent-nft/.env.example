# Deployer key (hex, with or without 0x). Required for deploy.
# DEPLOYER_PRIVATE_KEY=0x...

# Optional: RPC URLs (defaults to public Avalanche/Fuji)
# AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
# AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Optional: Snowtrace/Routescan API key (for verification)
# SNOWTRACE_API_KEY=
# SNOWTRACE_FUJI_API_URL=https://api.routescan.io/v2/network/testnet/evm/43113/etherscan/api
# SNOWTRACE_API_URL=https://api.routescan.io/v2/network/mainnet/evm/etherscan/api

# Base URI for token metadata (used in constructor). Should point at your API.
# AGENT_NFT_BASE_URI=https://your-api.example/api/v1/agent-nft/metadata/
